@model QuanLyThuVien.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h3 class="mb-4">Tổng quan hệ thống</h3>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="the-muc-luc" data-nhan="Đầu sách">
            <div class="so-lieu">@Model.TongSoDauSach</div>
            <div class="nhan-so-lieu">Tổng số đầu sách</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="the-muc-luc" data-nhan="Bản sách">
            <div class="so-lieu">@Model.TongSoSach</div>
            <div class="nhan-so-lieu">Tổng số bản sách</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="the-muc-luc" data-nhan="Độc giả">
            <div class="so-lieu">@Model.TongSoDocGia</div>
            <div class="nhan-so-lieu">Độc giả đăng ký</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="the-muc-luc" data-nhan="Đang mượn">
            <div class="so-lieu">@Model.SoPhieuDangMuon</div>
            <div class="nhan-so-lieu">Phiếu đang mượn</div>
        </div>
    </div>
</div>

@if (Model.SoPhieuQuaHan > 0)
{
    <div class="alert alert-danger">
        ⚠ Có <strong>@Model.SoPhieuQuaHan</strong> phiếu mượn đã quá hạn trả, cần nhắc độc giả.
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title">Top 5 sách được mượn nhiều nhất</h5>
        @if (Model.TopSachMuonNhieu.Any())
        {
            <canvas id="bieuDoTopSach" height="90"></canvas>
        }
        else
        {
            <p class="text-muted">Chưa có dữ liệu mượn sách.</p>
        }
    </div>
</div>

@section Scripts {
    @if (Model.TopSachMuonNhieu.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
        <script>
            const nhanBieuDo = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.TopSachMuonNhieu.Select(x => x.TenSach)));
            const soLieuBieuDo = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.TopSachMuonNhieu.Select(x => x.SoLuotMuon)));

            new Chart(document.getElementById('bieuDoTopSach'), {
                type: 'bar',
                data: {
                    labels: nhanBieuDo,
                    datasets: [{
                        label: 'Số lượt mượn',
                        data: soLieuBieuDo,
                        backgroundColor: '#0d6efd'
                    }]
                },
                options: {
                    responsive: true,
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                    plugins: { legend: { display: false } }
                }
            });
        </script>
    }
}
